LLM_SERVER_URLS=http://localhost:8888,http://localhost:8889,http://localhost:8890,http://localhost:8891
LLM_MODEL=local-model
LLM_HEALTH_PATH=/health
NUM_WORKERS=4
NUM_USERS=100
LOAD_TEST_THREADS=50
WORKER_THREADS=8
WORKER_QUEUE_SIZE=10
WORKER_MAX_IN_FLIGHT=18
LLM_TIMEOUT=180
LLM_HEALTH_TIMEOUT=5
LLM_MAX_TOKENS=64
SCHEDULER_REQUEST_TIMEOUT=30
SCHEDULER_ADMISSION_TIMEOUT=300
SCHEDULER_ADMISSION_POLL_INTERVAL=0.05
SCHEDULER_MAX_ATTEMPTS=2
WORKER_MAX_FAILURES=5
WORKER_FAILURE_COOLDOWN=20
WORKER_RECOVERY_SUCCESSES=2
FAULT_TOLERANCE_TEST_REQUESTS=8
LOAD_BALANCER_POLICY=adaptive
LB_EWMA_ALPHA=0.35
LB_UTILIZATION_WEIGHT=3.0
LB_QUEUE_WEIGHT=1.5
LB_LATENCY_WEIGHT=2.5
LB_IN_FLIGHT_AGE_WEIGHT=0.5
LB_FAILURE_WEIGHT=4.0
LB_STATE_DEGRADED_PENALTY=5.0
LB_STATE_RECOVERING_PENALTY=2.0
GPU_METRICS_URLS=
GPU_METRICS_PATH=/metrics
GPU_METRICS_INTERVAL=2
GPU_METRICS_TIMEOUT=2
ENABLE_MONITORING_DASHBOARD=false
MONITORING_HOST=127.0.0.1
MONITORING_PORT=8080
EVIDENCE_DIR=evaluation_results
RUN_ID=
RUN_FAULT_TOLERANCE_TESTS=false
